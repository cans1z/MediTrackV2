  "components": {
    "schemas": {
      "Frequency": {
        "enum": [
          "OnceADay",
          "TwiceADay",
          "ThriceADay",
          "EveryOtherDay",
          "Weekly"
        ],
        "type": "string"
      },
      "IntakeDto": {
        "required": [
          "scheduledAt"
        ],
        "type": "object",
        "properties": {
          "scheduledAt": {
            "type": "string",
            "format": "date-time"
          },
          "takenAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "isTaken": {
            "type": "boolean",
            "readOnly": true
          },
          "comment": {
            "type": "string",
            "nullable": true
          },
          "prescriptionId": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "IntakeResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "scheduledAt": {
            "type": "string",
            "format": "date-time"
          },
          "takenAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "isTaken": {
            "type": "boolean",
            "readOnly": true
          },
          "comment": {
            "type": "string",
            "nullable": true
          },
          "medicationName": {
            "type": "string",
            "nullable": true
          },
          "doctorName": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "userName": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "MedicationDto": {
        "required": [
          "dosageForm",
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "minLength": 2,
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "dosageForm": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "PrescriptionDto": {
        "required": [
          "dosage",
          "startDate"
        ],
        "type": "object",
        "properties": {
          "dosage": {
            "minLength": 1,
            "type": "string"
          },
          "frequency": {
            "$ref": "#/components/schemas/Frequency"
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "period": {
            "type": "integer",
            "format": "int32"
          },
          "isFlexible": {
            "type": "boolean"
          },
          "comment": {
            "type": "string",
            "nullable": true
          },
          "patientId": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "medicationId": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "PrescriptionResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "dosage": {
            "type": "string",
